{
  "manifest_version": 3,
  "name": "YT Chat Translator",
  "description": "Auto-translate YouTube comments and live chat.",
  "version": "1.0.0",
  "key": "",
  "icons": {
    "16": "icons/icon16.plasmo.6c567d50.png",
    "32": "icons/icon32.plasmo.76b92899.png",
    "48": "icons/icon48.plasmo.aced7582.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.plasmo.6c567d50.png",
      "32": "icons/icon32.plasmo.76b92899.png",
      "48": "icons/icon48.plasmo.aced7582.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "identity"],
  "oauth2": {
    "client_id": "488192202806-iqn1jk4jdnne8knegmkq7fio2nfjb71m.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://translate.googleapis.com/*",
    "https://translate-pa.googleapis.com/*",
    "https://edge.microsoft.com/*",
    "https://api-edge.cognitive.microsofttranslator.com/*",
    "https://translate.yandex.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/translator.js"],
      "css": ["content/translator.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
